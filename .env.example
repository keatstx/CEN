# CEN AI Concierge — Environment Configuration
# Copy to .env and adjust values as needed.

# LLM backend: "mock" | "gguf"
CEN_LLM_BACKEND=mock

# Path to GGUF model file (only used when CEN_LLM_BACKEND=gguf)
CEN_GGUF_MODEL_PATH=./models/model.gguf

# LLM timeout in seconds for graceful degradation fallback
CEN_LLM_TIMEOUT=10.0

# CORS allowed origins (comma-separated)
CEN_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging: "json" (production) | "console" (development)
CEN_LOG_RENDERER=console

# PII scrubbing: "regex" | "presidio"
CEN_PII_BACKEND=regex
